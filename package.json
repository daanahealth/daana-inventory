{
  "name": "daana-inventory",
  "private": true,
  "version": "0.0.0",
  "description": "Generic inventory management platform. DaanaRX MASS is the first domain pack.",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "dashboard": "node apps/dashboard/server/index.js",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm -r --filter \"./packages/*\" build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "typescript": "^5.6.0"
  }
}
